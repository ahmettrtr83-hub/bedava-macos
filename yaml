name: macOS-VNC-Baglantisi
on: workflow_dispatch

jobs:
  macos-calistir:
    runs-on: macos-13
    steps:
      - name: Ngrok Yukle
        run: brew install --cask ngrok
      
      - name: Ngrok Giris
        run: ngrok config add-authtoken "${{ secrets.NGROK_AUTH_TOKEN }}"
      
      - name: Ekran Paylasimini Ac (Sifresiz Mod)
        run: |
          # Mevcut kullanıcıyı (runner) şifre sormadan VNC'ye yetkili kılıyoruz
          sudo /System/Library/CoreServices/RemoteManagement/ARDAgent.app/Contents/Resources/kickstart -activate -configure -access -on -privs -all -allowAccessFor -allUsers
          
      - name: Tuneli Baslat
        run: |
          # VNC Portunu ac
          ngrok tcp --region eu 5900 > /dev/null &
          sleep 20
          # Baglanti linkini ver
          curl --silent http://127.0.0.1 | jq -r '.tunnels.public_url'
          
      - name: 6 Saat Acik Tut
        run: sleep 21600
